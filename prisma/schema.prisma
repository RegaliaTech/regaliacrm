// Regalia CMS — Prisma schema
// Single-company internal CMS: users/roles, customers, products,
// quotations, emails, and automated follow-ups.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  SALES
  ACCOUNTS
  VIEWER
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
  CHURNED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EmailDirection {
  OUTBOUND
  INBOUND
}

enum EmailStatus {
  DRAFT
  SENT
  FAILED
}

enum FollowUpStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum FollowUpReviewStatus {
  APPROVED
  PENDING_REVIEW
}

enum BulkEmailStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

enum BulkRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum SequenceStatus {
  ACTIVE
  COMPLETED
  STOPPED
  CANCELLED
}

enum SequenceStepStatus {
  SCHEDULED
  SENT
  SKIPPED
  FAILED
}

enum ProductKind {
  MODEL // fashion model / event host (expo, private & corporate events)
  PHOTOGRAPHER // event / studio photographer
  RENTAL // equipment available for rent
  CUSTOM // bespoke / made-to-order product
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  MARKETING
  MAINTENANCE
  OTHER
}

// ---------------------------------------------------------------------------
// Auth / Users
// ---------------------------------------------------------------------------

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(VIEWER)
  isActive       Boolean  @default(true)
  // Per-user commission override; null = use Settings.defaultCommissionRate
  commissionRate Decimal? @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customersOwned  Customer[]         @relation("CustomerOwner")
  quotations      Quotation[]        @relation("QuotationCreator")
  emails          EmailLog[]         @relation("EmailSender")
  followUps       FollowUp[]         @relation("FollowUpCreator")
  notes           CustomerNote[]
  settingsUpdates Settings[]         @relation("SettingsUpdater")
  bulkEmails      BulkEmail[]        @relation("BulkEmailCreator")
  sequences       FollowUpSequence[] @relation("SequenceCreator")
  expenses        Expense[]          @relation("ExpenseCreator")
  payments        Payment[]          @relation("PaymentCreator")
  vendorReceipts  VendorReceipt[]    @relation("VendorReceiptCreator")
}

// ---------------------------------------------------------------------------
// CRM — Customers & contacts
// ---------------------------------------------------------------------------

model Customer {
  id              String         @id @default(cuid())
  name            String
  company         String?
  email           String?
  phone           String?
  website         String?
  address         String?
  status          CustomerStatus @default(LEAD)
  tags            String[]       @default([])
  ownerId         String?
  owner           User?          @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // Engagement tracking for AI follow-up prioritisation
  lastContactedAt DateTime?
  lastRepliedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contacts       Contact[]
  notes          CustomerNote[]
  quotations     Quotation[]
  emails         EmailLog[]
  followUps      FollowUp[]
  sequences      FollowUpSequence[]
  bulkRecipients BulkEmailRecipient[]

  @@index([status])
  @@index([ownerId])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body       String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Product catalog — model / figure data
// ---------------------------------------------------------------------------

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  kind        ProductKind @default(MODEL)
  model       String?
  figure      String?
  category    String?
  description String?
  coverImage  String?
  // Flexible model/figure technical attributes (key/value specs)
  specs       Json?

  // Talent-specific (model / host / photographer when kind = MODEL | PHOTOGRAPHER)
  height      String? // e.g. "178 cm"
  weight      String? // e.g. "60 kg"
  nationality String?
  languages   String[] @default([])

  unitPrice Decimal @default(0) @db.Decimal(12, 2)
  unitCost  Decimal @default(0) @db.Decimal(12, 2)
  currency  String  @default("AED")
  isActive  Boolean @default(true)

  // Rental-specific (only meaningful when kind = RENTAL)
  dailyRate  Decimal? @db.Decimal(12, 2)
  weeklyRate Decimal? @db.Decimal(12, 2)
  deposit    Decimal? @db.Decimal(12, 2)
  qtyTotal   Int?
  qtyOnRent  Int      @default(0)

  // Custom-specific (only meaningful when kind = CUSTOM)
  isBespoke    Boolean @default(false)
  leadTimeDays Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images         ProductImage[]
  quotationItems QuotationItem[]
  vendorStock    VendorStock[]

  @@index([kind])
  @@index([category])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Quotations
// ---------------------------------------------------------------------------

model Quotation {
  id            String          @id @default(cuid())
  number        String          @unique
  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  creatorId     String?
  creator       User?           @relation("QuotationCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  status        QuotationStatus @default(DRAFT)
  currency      String          @default("AED")
  // Percentages
  taxRate       Decimal         @default(0) @db.Decimal(5, 2)
  discountRate  Decimal         @default(0) @db.Decimal(5, 2)
  notes         String?
  validUntil    DateTime?
  issuedAt      DateTime?
  // Payment tracking
  dueDate       DateTime?
  lastReminderAt DateTime?
  // Cached monetary totals
  subtotal      Decimal         @default(0) @db.Decimal(12, 2)
  discountTotal Decimal         @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal         @default(0) @db.Decimal(12, 2)
  total         Decimal         @default(0) @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items    QuotationItem[]
  emails   EmailLog[]
  payments Payment[]

  @@index([customerId])
  @@index([status])
}

model Payment {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(12, 2)
  paidAt      DateTime  @default(now())
  method      String?
  notes       String?
  createdById String?
  createdBy   User?     @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  description String
  quantity    Decimal   @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
  position    Int       @default(0)

  @@index([quotationId])
}

// ---------------------------------------------------------------------------
// Email log
// ---------------------------------------------------------------------------

model EmailLog {
  id             String                @id @default(cuid())
  customerId     String?
  customer       Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quotationId    String?
  quotation      Quotation?            @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  senderId       String?
  sender         User?                 @relation("EmailSender", fields: [senderId], references: [id], onDelete: SetNull)
  toEmail        String
  subject        String
  body           String
  status         EmailStatus           @default(DRAFT)
  aiGenerated    Boolean               @default(false)
  error          String?
  sentAt         DateTime?
  // Inbox (INBOUND) fields — populated by the IMAP sync job.
  direction      EmailDirection        @default(OUTBOUND)
  fromEmail      String?
  receivedAt     DateTime?
  messageId      String?               @unique
  inReplyTo      String?
  isRead         Boolean               @default(false)
  // Manual reply tracking + automation linkage
  repliedAt      DateTime?
  sequenceId     String?
  sequence       FollowUpSequence?     @relation(fields: [sequenceId], references: [id], onDelete: SetNull)
  sequenceStepId String?
  sequenceStep   FollowUpSequenceStep? @relation(fields: [sequenceStepId], references: [id], onDelete: SetNull)
  bulkEmailId    String?
  bulkEmail      BulkEmail?            @relation(fields: [bulkEmailId], references: [id], onDelete: SetNull)
  priorityScore  Int?
  createdAt      DateTime              @default(now())

  @@index([customerId])
  @@index([status])
  @@index([sequenceId])
  @@index([bulkEmailId])
  @@index([direction, receivedAt])
  @@index([fromEmail])
}

// ---------------------------------------------------------------------------
// Automated follow-ups
// ---------------------------------------------------------------------------

model FollowUp {
  id           String         @id @default(cuid())
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  creatorId    String?
  creator      User?          @relation("FollowUpCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  // The "case" / reason for this follow-up sequence
  caseSubject  String
  notes        String?
  // Email content to send (may be AI generated at send time if useAi=true)
  emailSubject String
  emailBody    String?
  useAi        Boolean        @default(false)
  status       FollowUpStatus @default(SCHEDULED)
  scheduledAt  DateTime
  sentAt       DateTime?
  error        String?
  // AI maintainer: was this auto-created, and does it need human sign-off
  // before the send worker picks it up?
  autoCreated  Boolean               @default(false)
  reviewStatus FollowUpReviewStatus  @default(APPROVED)
  // Groups gap type so the maintainer can avoid creating duplicates
  autoReason   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, scheduledAt])
  @@index([customerId])
  @@index([autoCreated, reviewStatus])
}

// ---------------------------------------------------------------------------
// Bulk email campaigns
// ---------------------------------------------------------------------------

model BulkEmail {
  id          String          @id @default(cuid())
  name        String
  subject     String
  body        String
  useAi       Boolean         @default(false)
  tone        String?
  status      BulkEmailStatus @default(DRAFT)
  createdById String?
  createdBy   User?           @relation("BulkEmailCreator", fields: [createdById], references: [id], onDelete: SetNull)
  total       Int             @default(0)
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  recipients BulkEmailRecipient[]
  emails     EmailLog[]

  @@index([status])
}

model BulkEmailRecipient {
  id          String              @id @default(cuid())
  bulkEmailId String
  bulkEmail   BulkEmail           @relation(fields: [bulkEmailId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  toEmail     String
  status      BulkRecipientStatus @default(PENDING)
  error       String?
  sentAt      DateTime?
  emailLogId  String?

  @@index([bulkEmailId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// AI follow-up sequences (multi-step, stop-on-reply)
// ---------------------------------------------------------------------------

model FollowUpSequence {
  id          String         @id @default(cuid())
  name        String
  customerId  String
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?          @relation("SequenceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  caseSubject String
  notes       String?
  useAi       Boolean        @default(true)
  tone        String         @default("friendly")
  stopOnReply Boolean        @default(true)
  status      SequenceStatus @default(ACTIVE)
  // Reference point: replies after this time stop the sequence
  startedAt   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  steps  FollowUpSequenceStep[]
  emails EmailLog[]

  @@index([status])
  @@index([customerId])
}

model FollowUpSequenceStep {
  id           String             @id @default(cuid())
  sequenceId   String
  sequence     FollowUpSequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepOrder    Int
  delayDays    Int                @default(0)
  status       SequenceStepStatus @default(SCHEDULED)
  scheduledAt  DateTime
  sentAt       DateTime?
  emailSubject String?
  emailBody    String?
  error        String?
  createdAt    DateTime           @default(now())

  emails EmailLog[]

  @@index([status, scheduledAt])
  @@index([sequenceId])
}

// ---------------------------------------------------------------------------
// Expenses / PNL
// ---------------------------------------------------------------------------

model Expense {
  id          String          @id @default(cuid())
  title       String
  category    ExpenseCategory @default(OTHER)
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("AED")
  incurredAt  DateTime
  notes       String?
  createdById String?
  createdBy   User?           @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([incurredAt])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Vendors — receipts & supplied stock
// ---------------------------------------------------------------------------

model Vendor {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipts VendorReceipt[]
  stock    VendorStock[]

  @@index([isActive])
}

model VendorReceipt {
  id            String   @id @default(cuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  receiptNumber String?
  description   String
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("AED")
  receiptDate   DateTime
  fileUrl       String?
  notes         String?
  createdById   String?
  createdBy     User?    @relation("VendorReceiptCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([vendorId])
  @@index([receiptDate])
}

model VendorStock {
  id              String    @id @default(cuid())
  vendorId        String
  vendor          Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  itemName        String
  quantity        Int       @default(0)
  unit            String    @default("pcs")
  reorderLevel    Int?
  lastRestockedAt DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vendorId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Settings (single-row configuration)
// ---------------------------------------------------------------------------

model Settings {
  id String @id @default(cuid())

  // Company/Business Information
  companyName    String  @default("Regalia CMS")
  companyLogo    String?
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  companyWebsite String?

  // Email/SMTP Configuration
  smtpHost     String?
  smtpPort     Int?    @default(587)
  smtpUsername String?
  smtpPassword String? // Consider encrypting in production
  smtpFrom     String?
  smtpFromName String?
  smtpSecure   Boolean @default(false) // Use TLS/SSL

  // Inbox (IMAP) — for pulling received emails into the CRM.
  imapHost     String?
  imapPort     Int?    @default(993)
  imapSecure   Boolean @default(true)
  imapUsername String?
  imapPassword String?
  inboxLastSyncedAt DateTime?

  // Business Defaults
  currency              String  @default("AED")
  defaultTaxRate        Decimal @default(5) @db.Decimal(5, 2)
  quotationPrefix       String  @default("QUO-")
  quotationValidityDays Int     @default(30)
  defaultCommissionRate Decimal @default(10) @db.Decimal(5, 2)

  // System Preferences
  timezone   String @default("Asia/Dubai")
  dateFormat String @default("DD/MM/YYYY")

  // Audit
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("SettingsUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("settings")
}
