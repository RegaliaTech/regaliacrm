# =============================================================================
# Regalia CRM — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# On Vercel, set these in Project → Settings → Environment Variables (Production
# + Preview), then redeploy — env changes don't apply to an existing build.
# =============================================================================

# ---- Database (Supabase Postgres) -------------------------------------------
# From the Supabase dashboard: Project Settings → Database → Connection string.
# DATABASE_URL: pooled connection (port 6543, PgBouncer) — used at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate`/`db push`.
DATABASE_URL="postgresql://postgres.xxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ---- Auth.js (NextAuth v5) --------------------------------------------------
# REQUIRED. Signs/verifies the session JWT — the app 500s on every sign-in
# without it. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-with-openssl-rand-base64-32"

# Public base URL of the app. Auto-detected on Vercel, but used directly to
# build absolute links (e.g. the quotation PDF URL in outgoing emails), so set
# it to your production domain in production. Defaults to http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# Dev-only: bypass login and render the UI as a stub admin before a database /
# auth is configured. Ignored when NODE_ENV=production. NEVER set to "true" in
# production — it would disable authentication entirely.
PREVIEW_NO_AUTH="false"

# ---- SMTP (outgoing email) --------------------------------------------------
# Use port 465 + SSL (recommended) or 587 + TLS/STARTTLS.
# Note: SMTP settings saved in the app's Settings page override these.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"             # true for 465/SSL, false for 587/STARTTLS
SMTP_USER="reach@regalia-vowstech.com"
SMTP_PASSWORD="your-mailbox-password"
SMTP_FROM="Regalia <reach@regalia-vowstech.com>"

# ---- AI provider ------------------------------------------------------------
# gemini | groq | mock. `mock` needs no key and returns canned replies.
AI_PROVIDER="gemini"
# Google Gemini free tier → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-lite-latest"   # optional; this is the default
# Optional Groq (free Llama models) → https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"         # optional; this is the default

# ---- File uploads (Vercel Blob) ---------------------------------------------
# REQUIRED for product image uploads. On Vercel, create a Blob store
# (Storage → Create → Blob) and it auto-injects this token; the /api/upload
# route returns 500 without it. For local dev, run `vercel env pull` or paste
# the store's token here.
BLOB_READ_WRITE_TOKEN=""

# ---- Cron security ----------------------------------------------------------
# REQUIRED for the scheduled workers (follow-ups, payment reminders, AI
# maintainer). Sent as a Bearer token; the endpoints 500 if it's unset. Use any
# strong random string.
CRON_SECRET="change-me-cron-secret"

# ---- AI maintainer ----------------------------------------------------------
# Auto-creates follow-ups for gaps: stale leads, quotations about to expire,
# and stale failed follow-ups.
AI_MAINTAINER_ENABLED="false"        # true to let the cron worker create follow-ups
AI_MAINTAINER_DRY_RUN="false"        # true to log what would be created without writing
AI_MAINTAINER_REQUIRE_REVIEW="false" # true to require human approval before auto-created follow-ups can send
